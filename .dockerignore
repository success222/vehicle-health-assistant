cat > .dockerignore << 'EOF'
# Environment & secrets
.env
.env.*

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environment
.venv/
venv/
env/

# Logs
logs/
*.log

# Testing
.pytest_cache/
.coverage
htmlcov/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Git
.git/
.gitignore

# # Docker
# Dockerfile
# .dockerignore
# EOF

logs/
*.log